# Supabase
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
# PERINGATAN: service_role key memberi akses penuh database.
# JANGAN gunakan key ini di sisi client/browser.
# Hanya boleh ada di environment variabel server (Vercel/backend).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenRouter AI
OPENROUTER_API_KEY=your-openrouter-key-here

# Fitur opsional
AAI_REASONING_PREVIEW_ENABLED=false
